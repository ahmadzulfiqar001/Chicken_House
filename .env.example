# Chicken House — environment variables.
# Copy to .env for local dev, and set the same keys in Vercel → Project → Settings
# → Environment Variables (Production + Preview). Do NOT set NODE_ENV (Vercel sets it).

# MongoDB Atlas connection string (required for persistence; without it the app
# falls back to non-persistent in-memory data).
MONGODB_URI=

# Comma-separated allowed origin(s) for the realtime Socket.IO CORS on the
# long-running server. Unused by the Vercel function (no socket server there);
# set it to your production URL for parity.
APP_ORIGIN=

# Meta WhatsApp Cloud webhook (optional — enables the WhatsApp bot).
META_WA_VERIFY_TOKEN=
META_WA_ACCESS_TOKEN=
META_WA_PHONE_NUMBER_ID=
META_WA_ADMIN_NUMBER=
META_WA_APP_SECRET=

# Groq AI assistant (optional — without a key the assistant uses the rule-based engine).
GROQ_API_KEY=
GROQ_MODEL=

# Resend transactional email (optional).
RESEND_API_KEY=
RESEND_FROM=
